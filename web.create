<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pani Puri Shop</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#fff8e7;
}

header{
    background:#ff6b00;
    color:white;
    text-align:center;
    padding:20px;
}

nav{
    background:#333;
    text-align:center;
    padding:12px;
}

nav a{
    color:white;
    text-decoration:none;
    margin:0 15px;
    font-size:18px;
}

.hero{
    text-align:center;
    padding:60px 20px;
    background:#ffe0b2;
}

.hero h1{
    font-size:45px;
    color:#d84315;
}

.hero p{
    font-size:20px;
    margin-top:10px;
}

.products{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:20px;
    padding:40px;
}

.card{
    width:250px;
    background:white;
    border:2px solid #ff9800;
    border-radius:10px;
    text-align:center;
    padding:15px;
}

.card img{
    width:100%;
    height:180px;
    border-radius:10px;
}

.card h3{
    margin:10px 0;
}

.price{
    color:green;
    font-size:22px;
    font-weight:bold;
}

button{
    background:#ff6b00;
    color:white;
    border:none;
    padding:10px 20px;
    margin-top:10px;
    cursor:pointer;
    border-radius:5px;
}

footer{
    background:#333;
    color:white;
    text-align:center;
    padding:15px;
}
</style>

</head>
<body>

<header>
    <h1>🌮 Super Pani Puri Shop</h1>
    <p>Fresh • Tasty • Hygienic</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Menu</a>
    <a href="#">Offers</a>
    <a href="#">Contact</a>
</nav>

<section class="hero">
    <h1>Welcome to Super Pani Puri Shop</h1>
    <p>Enjoy the Best Street Food in Town!</p>
</section>

<section class="products">

    <div class="card">
        <img src="https://images.unsplash.com/photo-1601050690597-df0568f70950?w=500" alt="Pani Puri">
        <h3>Classic Pani Puri</h3>
        <p class="price">₹30</p>
        <button>Order Now</button>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=500" alt="Masala Puri">
        <h3>Masala Puri</h3>
        <p class="price">₹40</p>
        <button>Order Now</button>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=500" alt="Dahi Puri">
        <h3>Dahi Puri</h3>
        <p class="price">₹50</p>
        <button>Order Now</button>
    </div>

</section>

<footer>
    <p>&copy; 2026 Super Pani Puri Shop | All Rights Reserved</p>
</footer>

</body>
</html>